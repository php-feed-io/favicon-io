{
    "name": "php-feed-io/favicon-io",
    "description": "PHP library for fetching favicons",
    "keywords": ["favicon", "fetch", "icon"],
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Benjamin Brahmer",
            "email": "info@b-brahmer.de"
        }
    ],
    "require": {
        "php": ">=8.2",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.1",
        "psr/http-message": "^2.0"
    },
    "suggest": {
        "psr/simple-cache": "^3.0 — provide a PSR-16 cache to avoid re-discovering favicons on every call",
        "psr/log": "^3.0 — provide a PSR-3 logger to receive debug-level HTTP error messages"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.1",
        "psr/simple-cache": "^3.0",
        "psr/log": "^3.0",
        "nyholm/psr7": "^1.8"
    },
    "autoload": {
        "psr-4": {"FeedIo\\FaviconIo\\": "src/FaviconIo"}
    },
    "autoload-dev": {
        "psr-4": {"FeedIo\\FaviconIo\\": "tests/FaviconIo"}
    },
    "scripts": {
        "src:php-stan": "./vendor/bin/phpstan analyse src/ --level 9",
        "src:test": "./vendor/bin/phpunit"
    },
    "config": {
        "preferred-install": {
            "*": "dist"
        }
    }
}
