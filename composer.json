{
    "name": "php-feed-io/favicon-io",
    "description": "PHP library for fetching favicons",
    "keywords": ["favicon", "fetch", "icon"],
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Alexandre Debril",
            "email": "alex.debril@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.1"
    },
    "autoload": {
        "psr-4": {"FaviconIo\\": "src/FaviconIo"}
    },
    "autoload-dev": {
        "psr-4": {"FaviconIo\\": "tests/FaviconIo"}
    },
    "scripts": {
        "src:php-stan": "./vendor/bin/phpstan analyse src/ --level 5",
        "src:test": "./vendor/bin/phpunit"
    },
    "config": {
        "preferred-install": {
            "*": "dist"
        }
    }
}
